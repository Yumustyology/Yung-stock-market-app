# Copy this file to .env.local and fill values
NODE_ENV=development
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# MongoDB
MONGODB_URI=mongodb://localhost:27017/stock-market-app

# Better Auth
BETTER_AUTH_SECRET=replace_with_a_long_random_secret
BETTER_AUTH_API_KEY=replace_with_better_auth_api_key
BETTER_AUTH_URL=http://localhost:3000

# Finnhub
FINNHUB_API_KEY=replace_with_finnhub_server_api_key
NEXT_PUBLIC_FINNHUB_API_KEY=replace_with_finnhub_public_api_key

# Gemini
GEMINI_API_KEY=replace_with_gemini_api_key

# Brevo
BREVO_API_KEY=replace_with_brevo_api_key
BREVO_SENDER_EMAIL=replace_with_sender_email@example.com
BREVO_SENDER_NAME=Signalist
